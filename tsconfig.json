{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "outDir": "dist",
    "rootDir": ".",
  },
  "include": ["scripts/**/*.ts", "tests/**/*.ts", "src/**/*.ts"],
  "exclude": ["node_modules", "docs-output", "naive"],
}
